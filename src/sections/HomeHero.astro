<section id="home" class="relative container flex min-h-screen flex-col items-center justify-center text-center">
    <div
        class="aos show:translate-x-0 absolute top-1/2 left-10 hidden -translate-x-8 -translate-y-1/2 grid-cols-3 gap-2 transition-all delay-400 duration-1000 ease-out lg:grid">
        {Array.from({ length: 12 }).map(() => <div class="bg-primary h-9 w-9 rounded-full" />)}
    </div>
    <div
        class="aos show:translate-x-0 absolute top-1/2 right-10 hidden translate-x-8 -translate-y-1/2 grid-cols-3 gap-2 transition-all delay-400 duration-1000 ease-out lg:grid">
        {Array.from({ length: 12 }).map(() => <div class="15 bg-primary h-9 w-9 rounded-full" />)}
    </div>

    <h1 class="mb-2 text-5xl leading-12 font-black tracking-wide uppercase md:text-7xl">
        <span class="aos show:animate-fade-up inline-block opacity-0">Lokal</span><br />
        <span
            class="aos show:animate-fade-up show:animate-delay-200 text-primary inline-block delay-300">
            Kreatif
        </span>
    </h1>
    <h2
        class="aos show:animate-fade-up show:animate-delay-300 mb-8 text-xl font-semibold tracking-wider md:text-2xl">
        create a
        <span
            id="text-wrapper"
            class="inline-block overflow-hidden align-bottom transition-[width] duration-500 ease-in-out">
            <span id="dynamic-text" class="text-primary inline-block underline transition-all duration-500 whitespace-nowrap">
                website
            </span>
        </span>
        <p
            class="aos show:animate-fade-up show:animate-delay-400 max-w-2xl text-sm mt-8 leading-relaxed text-gray-400 md:text-base">
            Bring your ideas to life with Lokal Kreatif! We handle all your digital and visual needs—from seamless
            programming and stunning designs, to aesthetic photos and videos.
        </p>
    </h2>
    <script>
        const words = ['website', 'branding', 'design', 'apps', 'photo & video'];

        const wrapper = document.getElementById('text-wrapper');
        const textElement = document.getElementById('dynamic-text');

        const ruler = document.createElement('span');
        ruler.className = textElement.className + ' absolute text-xl md:text-2xl font-semibold tracking-wider pointer-events-none opacity-0 -z-10';
        document.body.appendChild(ruler);

        ruler.innerText = words[0];
        wrapper.style.width = `${ruler.offsetWidth}px`;

        let currentIndex = 0;

        setInterval(() => {
            textElement.classList.remove('opacity-100', 'translate-y-0');
            textElement.classList.add('opacity-0', 'translate-y-4');

            setTimeout(() => {
                currentIndex = (currentIndex + 1) % words.length;
                const nextWord = words[currentIndex];

                textElement.innerText = nextWord;

                ruler.innerText = nextWord; 
                const newWidth = ruler.offsetWidth; 

                wrapper.style.width = `${newWidth}px`;

                textElement.classList.remove('opacity-0', 'translate-y-4');
                textElement.classList.add('opacity-100', 'translate-y-0');
            }, 500); 
        }, 3000); 
    </script>
</section>
