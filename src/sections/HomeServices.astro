---
const services = [
    {
        title: 'Website & App Developer',
        description: 'Build a website or app to grow your business',
        img: 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=600&q=80',
    },
    {
        title: 'Graphic Design',
        description: 'Create a business design with creative and modern results',
        img: 'https://images.unsplash.com/photo-1561070791-2526d30994b5?auto=format&fit=crop&w=600&q=80',
    },
    {
        title: 'Photos, videos, and editing',
        description: 'Showcase your business in the best possible light',
        img: 'https://images.unsplash.com/photo-1502209877429-d7c6df9eb3f9?auto=format&fit=crop&w=600&q=80',
    },
];

---

<section id="service" class="container py-16">
    <div class="mb-12 text-center">
        <h3 class="aos show:animate-fade-up text-primary text-lg font-bold">Service</h3>
        <p class="aos show:animate-fade-up show:animate-delay-200 text-sm text-gray-400">We provide the best service to aim times.</p>
    </div>

    <div class="mx-auto grid max-w-5xl grid-cols-1 gap-6 md:grid-cols-3">
        {
        services.map((service, index) => (
            <div class="aos show:animate-fade-up group relative h-72 cursor-pointer overflow-hidden rounded-2xl" 
        style=`animation-delay: ${index * 150}ms;`>
                    <img
                        src={service.img}
                        alt={service.title}
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent" />

                    <div class="absolute bottom-0 left-0 w-full px-6 py-6">
                        <h4 class="text-lg leading-tight font-bold">{service.title}</h4>
                        <div class="grid-rows-[0fr] grid overflow-hidden mt-0 group-hover:mt-2.5 transition-all duration-500 group-hover:grid-rows-[1fr]">
                            <div class="min-h-0">
                                <p>{service.description}</p>
                            </div>
                        </div>
                 
                    </div>
                </div>
            ))
        }
    </div>
</section>
