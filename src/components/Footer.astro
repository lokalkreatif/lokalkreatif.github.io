---
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.png';
---
<footer class="mt-10 border-t border-gray-800">
    <div class="container flex flex-col items-start justify-between gap-8 py-12 md:flex-row">
        <div class="max-w-xs">
            <div class="mb-4 flex items-center gap-2">
                <Image src={logoImg} alt="" class="h-12 w-auto object-contain" />
            </div>
            <p class="text-xs text-gray-500">
                Jl. Jendral Sudirman Kav. 21,<br />
                DKI Jakarta, Indonesia
            </p>
        </div>

        <div class="flex gap-16">
            <div>
                <h4 class="mb-4 text-sm font-bold">Company</h4>
                <ul class="space-y-2 text-xs text-gray-400">
                    <li><a href="#home" class="hover:text-white">Home</a></li>
                    <li><a href="#service" class="hover:text-white">Service</a></li>
                    <li><a href="#portfolio" class="hover:text-white">Portfolio</a></li>
                </ul>
            </div>
        </div>

        <div class="flex flex-col gap-3">
            <button
                class="bg-primary rounded-md px-6 py-2 text-sm font-semibold text-black transition-colors hover:bg-white">
                Contact Us
            </button>
            <button
                class="bg-primary rounded-md px-6 py-2 text-sm font-semibold text-black transition-colors hover:bg-white">
                Hire Us
            </button>

            <div class="mt-4 flex gap-4 text-gray-400">
                <span class="cursor-pointer hover:text-white">IG</span>
                <span class="cursor-pointer hover:text-white">TW</span>
                <span class="cursor-pointer hover:text-white">FB</span>
                <span class="cursor-pointer hover:text-white">LI</span>
            </div>
        </div>
    </div>

    <div class="border-t border-gray-900 py-4 text-center text-xs text-gray-600">
        &copy; 2024 Lokal Kreatif. All Rights Reserved.
    </div>
</footer>
